#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/backlight.h>
#include "elpekenin/behaviors.dtsi"
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/ext_power.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 100
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/mouse.h>
#include <input/processors/xyz.dtsi> // Used to compress data from peripheral trackpad

/* enums to set in sources to filter events in zmk,output-behavior-listener */
#define OUTPUT_SOURCE_LAYER_STATE_CHANGE        1 // Layer change
#define OUTPUT_SOURCE_POSITION_STATE_CHANGE     2 // when a key is pressed in
#define OUTPUT_SOURCE_KEYCODE_STATE_CHANGE      3 // When a keycode is sent
#define OUTPUT_SOURCE_MOUSE_BUTTON_STATE_CHANGE 4
#define OUTPUT_SOURCE_MOUSE_WHEEL_STATE_CHANGE  5
#define OUTPUT_SOURCE_TRANSPORT                 6 // I assume the fancy host notify

// Layer numbers for use by the keymap & macros
#define MACOS     0
#define WINDOWS   1
#define M_SYMBOLS 2
#define W_SYMBOLS 3
#define NUMPAD    4
#define M_FKEYS   5
#define W_FKEYS   6
#define KB_CONFIG 7
#define MOUSE_MAP 8

&sk {
    release-after-ms = <500>;
    quick-release;
    /delete-property/ ignore-modifiers;
};

&mt {
    tapping-term-ms = <250>;
};

#include "rolio-macros.dtsi"
//#include "rolio-macros-haptic.dtsi"
#include "rolio-behaviors.dtsi"


// Helpful macros borrowed from AndrewMSHowe
#define ___ &trans

// Configure the pointer acceleration:
//
//     Relevant doc: https://github.com/oleksandrmaslov/zmk-pointing-acceleration
//
#include <input/processors.dtsi>
#include <behaviors/input_gestures_accel.dtsi>

&pointer_accel {
    input-type = <INPUT_EV_REL>; // For relative input devices
    track-remainders;            // Accumulate fractional movements
    min-factor = <800>;          // 0.8x at very slow speeds
    max-factor = <4000>;         // 4.0x at fast speeds
    speed-threshold = <1200>;    // 1200 counts/sec for 1x
    speed-max = <9001>;          // Over 9000 counts/sec for max accel
    acceleration-exponent = <2>; // Quadratic acceleration curve
};

/ {

    trackpad_configuration {
        // Translate trackpad movement to mouse wheel movement
        to_wheel: to_wheel {
            compatible = "zmk,input-processor-code-mapper";
            #input-processor-cells = <0>;
            type = <INPUT_EV_REL>;
            map = <INPUT_REL_X INPUT_REL_HWHEEL>
                , <INPUT_REL_Y INPUT_REL_WHEEL>;
        };

        // Customise the trackpad behaviour for different layers
        glidepoint_listener {
            compatible = "zmk,input-listener";
            device = <&glidepoint_split>;
            input-processors = <&zip_zxy> 
                , <&zip_xy_scaler 3 1>
                , <&pointer_accel>
                , <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP)>
                , <&zip_temp_layer MOUSE_MAP 500>;

            scroll_for_fkeys {
                layers = <M_FKEYS>, <W_FKEYS>;
                input-processors = <&zip_zxy>
                    , <&zip_xy_scaler 1 18>
                    , <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP)>
                    , <&to_wheel>
                    , <&zip_scroll_transform (INPUT_TRANSFORM_Y_INVERT)>;
            };
        };

        // If using mouse keys in the mouse layer make it stick
        sticky_mouse_layer {
            compatible = "zmk,output-behavior-listener";
            layers = < MOUSE_MAP >;
            sources = < OUTPUT_SOURCE_MOUSE_WHEEL_STATE_CHANGE>;
            bindings = < &to MOUSE_MAP >;
            all-state;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "MacOS";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>;
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
       &kp GRAVE      &kp Q            &kp W           &kp E           &kp R           &kp T     /*|                                 |*/  &kp Y          &kp U           &kp I           &kp O           &kp P          &kp BSPC
       &kp TAB        &kp A            &kp S           &kp D           &kp F           &kp G     /*|                                 |*/  &kp H          &kp J           &kp K           &kp L           &kp SEMI       &kp SQT
       &sk LSHIFT     &kp Z            &kp X           &kp C           &kp V           &kp B     /*├─────────────╮     ╭─────────────┤*/  &kp N          &kp M           &kp COMMA       &kp DOT         &kp FSLH       &scw RSHIFT 0
/* ╰───────────────┴───────────────┤*/ &mo KB_CONFIG   &kp LALT        &kp LCTRL       &kp LGUI   &lt M_FKEYS ENTER   &lt NUMPAD SPACE    &td1_mac       &mt RGUI K_APP  &kp RCTRL       &kp DEL   //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴───────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
        };

        windows_default_layer {
            display-name = "Windows";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>;
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
       &kp GRAVE      &kp Q            &kp W           &kp E           &kp R           &kp T     /*|                                 |*/  &kp Y          &kp U           &kp I           &kp O           &kp P          &kp BSPC
       &kp TAB        &kp A            &kp S           &kp D           &kp F           &kp G     /*|                                 |*/  &kp H          &kp J           &kp K           &kp L           &kp SEMI       &kp SQT
       &sk LSHIFT     &kp Z            &kp X           &kp C           &kp V           &kp B     /*├─────────────╮     ╭─────────────┤*/  &kp N          &kp M           &kp COMMA       &kp DOT         &kp FSLH       &scw RSHIFT 0
/* ╰───────────────┴───────────────┤*/ &mo KB_CONFIG   &kp LGUI        &kp LALT        &kp LCTRL   &lt W_FKEYS ENTER  &lt NUMPAD SPACE    &td1_win       &mt RCTRL K_APP    &kp RALT        &kp DEL   //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴───────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
        };

        macos_symbols_layer {
            display-name = "Symbols (Mac)";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>;
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
       &kp UNDER       &kp N1          &kp N2          &kp N3          &kp N4          &kp N5    /*|                                 |*/  &kp N6         &kp N7          &kp N8          &kp N9          &kp N0          &kp DEL
       ___             &kp EXCL        &kp AT          &kp HASH        &kp DLLR        &kp PRCNT /*|                                 |*/  &kp CARET      &kp AMPERSAND   &kp STAR        &kp LPAR        &kp RPAR        &kp MINUS
       ___         &kp LC(LG(SPACE))   &kp LEFT_BRACE  &kp RIGHT_BRACE &kp PIPE        &kp EQUAL /*├─────────────╮     ╭─────────────┤*/  &kp PRCNT      &kp PLUS        &kp LBKT        &kp RBKT        &kp BACKSLASH   ___
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___             ___                 ___            ___            ___             ___             ___       //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴───────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
        };

        windows_symbols_layer {
            display-name = "Symbols (Win)";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
       &kp UNDER       &kp N1          &kp N2          &kp N3          &kp N4          &kp N5    /*|                                 |*/  &kp N6         &kp N7          &kp N8          &kp N9          &kp N0          &kp DEL
       ___             &kp EXCL        &kp AT          &kp HASH        &kp DLLR        &kp PRCNT /*|                                 |*/  &kp CARET      &kp AMPERSAND   &kp STAR        &kp LPAR        &kp RPAR        &kp MINUS
       ___             &kp LG(DOT)     &kp LEFT_BRACE  &kp RIGHT_BRACE &kp PIPE        &kp EQUAL /*├─────────────╮     ╭─────────────┤*/  &kp PRCNT      &kp PLUS        &kp LBKT        &kp RBKT        &kp BACKSLASH   ___
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___             ___                 ___            ___            ___             ___             ___       //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴───────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
        };

        numpad_layer {
            display-name = "Number Pad";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
       ___             &kp N1          &kp N2          &kp N3          &kp N4          &kp N5    /*|                                 |*/  &kp N6         &kp N7          &kp N8          &kp N9          &kp N0          ___ 
       ___             &kp EXCL        &kp AT          &kp HASH        &kp DLLR        &kp PRCNT /*|                                 |*/  &kp CARET      &kp N4          &kp N5          &mt LPAR N6     &mt RPAR PLUS   &kp MINUS
       ___             ___             &kp LEFT_BRACE  &kp RIGHT_BRACE &kp PIPE        &kp EQUAL /*├─────────────╮     ╭─────────────┤*/  &kp PRCNT      &kp N1          &mt COMMA N2    &mt DOT N3      &kp KP_DIVIDE   &kp KP_MULTIPLY
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___             ___                 ___            &hnt           &kp N0          &kp KP_DOT      ___       //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴───────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
      };


        macos_f_keys_layer {
            display-name = "F Keys (Mac)";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬────────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
  &usb_tog OUT_TOG ESCAPE &btkp 0 F1   &btkp 1 F2      &btkp 2 F3      &btkp 3 F4      &btkp 4 F5 /*|                                 |*/   &kp F6         &kp F7          &kp F8          &kp F9          &kp F10         &kp F11
      &kp LS(TAB)      &mac_talk       ___             &kp C_PREV      &kp C_PP        &kp C_NEXT /*|                                 |*/   &kp LG(LEFT)   &kp UP          &kp LG(RIGHT)   &mac_cap_app    &kp PG_UP       &kp F12
      ___              &ug_on          &ug_off         &kp C_VOL_DN    &kp C_MUTE      &kp C_VOL_UP/*├────────────╮     ╭─────────────┤*/    &kp LEFT       &kp DOWN        &kp RIGHT       &kp LG(LS(N4))  &kp PG_DN       &kp F13
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___              ___                ___              ___            ___             ___             ___      //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴────────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;
        };

        windows_f_keys_layer {
            display-name = "F Keys (Win)";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬────────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
  &usb_tog OUT_TOG ESCAPE &btkp 0 F1   &btkp 1 F2      &btkp 2 F3      &btkp 3 F4      &btkp 4 F5 /*|                                 |*/   &kp F6         &kp F7          &kp F8          &kp F9          &kp F10         &kp F11
      &kp LS(TAB)      &mac_talk       ___             &kp C_PREV      &kp C_PP        &kp C_NEXT /*|                                 |*/   &kp HOME       &kp UP          &kp END         &kp LA(PSCRN)   &kp PG_UP       &kp F12
      ___              &ug_on          &ug_off         &kp C_VOL_DN    &kp C_MUTE      &kp C_VOL_UP/*├────────────╮     ╭─────────────┤*/   &kp LEFT       &kp DOWN        &kp RIGHT       &kp LG(LS(S))   &kp PG_DN       &kp F13
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___             ___                 ___              ___            ___             ___             ___      //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴────────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;

        };


      settings_layer {
            display-name = "Settings";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬────────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
      &out OUT_TOG     &btkp 0 N1      &btkp 1 N2      &btkp 2 N3      &btkp 3 N4     &btkp 4 N5  /*|                                 |*/   &kp N6         &kp N7          &kp N8          &kp N9          &kp N0          &soft_off
      ___              ___             ___             &rgb_ug RGB_EFR &color_ug  &rgb_ug RGB_EFF /*|                                 |*/   ___            &kp N4          &kp N5          &kp N6          ___             ___
      ___              ___             &btclr_kp X X   &rgb_ug RGB_SPD &white_ug  &rgb_ug RGB_SPI /*├─────────────╮     ╭─────────────┤*/    ___            &kp N1          &kp N2          &kp N3          ___             ___
/* ╰───────────────┴───────────────┤*/ ___             &df_win         ___            &df_mac           ___                  ___            ___            &kp N0          ___             ___      //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴────────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯   
            >;
        };

        mouse_layer {
            display-name = "Trackpad";
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp PG_DN PG_UP>
            bindings = <
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬────────────────╮                                 ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
      &tog MOUSE_MAP   ___             ___             ___             ___             ___        /*|                                 |*/   &mkp RCLK      &mkp MB4        &mkp MB5        ___             ___           &tog MOUSE_MAP 
      ___              ___             ___             ___             ___             ___        /*|                                 |*/   &mkp MCLK      ___             ___             ___             ___           ___
      ___              ___             ___             ___             ___             ___        /*├─────────────╮     ╭─────────────┤*/   ___            ___             ___             ___             ___           ___
/* ╰───────────────┴───────────────┤*/ ___             ___             ___             ___             ___                 &mkp LCLK        &mkp RCLK      ___             ___             ___      //├───────────────┴───────────────╯
//                                 ╰───────────────┴───────────────┴───────────────┴────────────────┴─────────────╯     ╰─────────────┴───────────────┴───────────────┴───────────────┴───────────────╯
            >;

        };

        // Extra layers for ZMK Studio
        extra1 {
            status = "reserved";
        };
        extra2 {
            status = "reserved";
        };
        extra3 {
            status = "reserved";
        };

    };

};
